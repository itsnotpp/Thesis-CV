generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String?
  role          String         @default("USER") // USER, EXPERT, ADMIN
  isVerified    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  profile       Profile?
  settings      Settings?
  connectionsSent     Connection[]  @relation("ConnectionsSent")
  connectionsReceived Connection[]  @relation("ConnectionsReceived")
  publications        Publication[] @relation("PublicationAuthors")
  education           Education[]
  experience          Experience[]
  
  invitesSent         CollaborationInvite[] @relation("InvitesSent")
  invitesReceived     CollaborationInvite[] @relation("InvitesReceived")
}

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  
  // Personal Info
  prefix        String?
  firstName     String?
  lastName      String?
  academicTitle String?
  jobTitle      String?
  organization  String?
  bio           String?
  avatarUrl     String?
  coverUrl      String?
  keywords      String?

  // Contact Info
  email         String?
  phone         String?
  location      String?

  updatedAt     DateTime @updatedAt
}

model Settings {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  
  publicProfile   Boolean  @default(true)
  hideContactInfo Boolean  @default(false)
  darkMode        Boolean  @default(false)
  language        String   @default("th")
  emailAlerts     Boolean  @default(true)
  aiMatchAlerts   Boolean  @default(true)

  updatedAt       DateTime @updatedAt
}

model Connection {
  id          String   @id @default(uuid())
  userId      String
  connectedId String
  status      String   @default("PENDING") // PENDING, ACCEPTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("ConnectionsSent", fields: [userId], references: [id])
  connected   User     @relation("ConnectionsReceived", fields: [connectedId], references: [id])

  @@unique([userId, connectedId])
}

model Publication {
  id          String   @id @default(uuid())
  title       String
  type        String?  // Research, Article, etc.
  year        Int?
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authors     User[]   @relation("PublicationAuthors")
}

model Education {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  degree      String
  institution String
  year        Int?
  details     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  title       String
  company     String
  startDate   String?
  endDate     String?
  current     Boolean  @default(false)
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CollaborationInvite {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  type        String   @default("EVALUATE") // EVALUATE, RESEARCH, OTHER
  message     String?
  status      String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender      User     @relation("InvitesSent", fields: [senderId], references: [id])
  receiver    User     @relation("InvitesReceived", fields: [receiverId], references: [id])
}